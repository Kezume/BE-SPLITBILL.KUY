## Tahap 3: Service â€” [NEW] `internal/service/expense_service.go`

```go
type ExpenseService interface {
    CreateExpense(ctx context.Context, req dto.CreateExpenseRequest) error
    DeleteExpense(ctx context.Context, expenseID string, userID string) error
}
```

### Logika `CreateExpense`:

```go
func (s *expenseService) CreateExpense(ctx context.Context, req dto.CreateExpenseRequest) error {
    // 1. Parse tanggal
    date, err := time.Parse("2006-01-02", req.Date)

    // 2. Buat record expense
    expense := model.Expense{
        GroupID:     uuid.Must(uuid.Parse(req.GroupID)),
        Description: req.Description,
        Amount:      req.Amount,
        PaidBy:      uuid.Must(uuid.Parse(req.PaidBy)),
        Date:        date,
    }
    err = s.repo.CreateExpense(ctx, &expense)

    // 3. Hitung split
    var splits []model.ExpenseSplit

    if req.SplitType == "equal" {
        perPerson := req.Amount / uint64(len(req.SplitWith))
        for _, s := range req.SplitWith {
            splits = append(splits, model.ExpenseSplit{
                ExpenseID: expense.ID,
                UserID:    uuid.Must(uuid.Parse(s.UserID)),
                Amount:    perPerson,
            })
        }
    } else { // custom
        // Validasi: total split harus == total amount
        var totalSplit uint64
        for _, s := range req.SplitWith {
            totalSplit += s.Amount
        }
        if totalSplit != req.Amount {
            return errors.New("Total split gak sesuai sama total biaya!")
        }

        for _, s := range req.SplitWith {
            splits = append(splits, model.ExpenseSplit{
                ExpenseID: expense.ID,
                UserID:    uuid.Must(uuid.Parse(s.UserID)),
                Amount:    s.Amount,
            })
        }
    }

    // 4. Simpan splits
    return s.repo.CreateExpenseSplits(ctx, splits)
}
```

